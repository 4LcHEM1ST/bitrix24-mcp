# Bitrix24 incoming webhook URL
# Generate one at: Your Portal → Applications → Webhooks → Incoming webhooks
B24_DEFAULT_WEBHOOK=https://your-portal.bitrix24.com/rest/1/your-token/

# (Optional) Comma-separated list of required scopes — used for validation warnings only
# B24_REQUIRED_SCOPES=crm,tasks,calendar,user,department,disk,im,bizproc,catalog

# ─── Transport & remote access (HTTP + Google OAuth) ─────────────────────────
# stdio (default, local next to Claude Desktop) or http (remote server with OAuth).
B24_TRANSPORT=stdio

# Listen address/port (http mode).
# In Docker this MUST be 0.0.0.0, otherwise the port won't map and nginx gets 502.
# 127.0.0.1 is only for running http directly on the host (outside a container).
B24_HOST=0.0.0.0
B24_PORT=8001

# Public https URL of the server (used to build the OAuth redirect URI). No trailing slash.
# The Google redirect URI must be exactly: <B24_PUBLIC_URL>/auth/callback
B24_PUBLIC_URL=

# Google OAuth app credentials (Google Cloud Console).
B24_GOOGLE_CLIENT_ID=
B24_GOOGLE_CLIENT_SECRET=

# Email allowlist, comma-separated. REQUIRED in http mode — it is the only barrier
# of WHO may use the shared webhook. Without it any Google user would get in.
B24_ALLOWED_EMAILS=manager.ges.07@gmail.com

# (Optional) Path where the OAuth provider persists clients/tokens so they survive
# a restart. In Docker this is preset to /data/oauth-state.json (see Dockerfile)
# and backed by the oauth-data volume. Empty → in-memory only (tokens lost on restart).
# B24_OAUTH_STORE_PATH=/data/oauth-state.json
